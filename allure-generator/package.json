{
  "name": "allure-generator",
  "version": "1.0.0",
  "description": "Allure Report",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git@git@github.com:allure-framework/allure2.git"
  },
  "author": "Dmitry Baev",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-brush": "^3.0.6",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-dsv": "^3.0.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^24.12.2",
    "ansi-to-html": "^0.7.2",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "playwright": "^1.59.1",
    "rimraf": "^5.0.5",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-drag": "^3.0.0",
    "d3-dsv": "^3.0.1",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "filesize": "^10.1.1",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.5",
    "normalize-css": "^2.3.1",
    "split.js": "^1.6.4"
  },
  "browserslist": [
    "last 2 Chrome major versions",
    "last 2 Edge major versions",
    "last 2 Firefox major versions",
    "last 2 Safari major versions"
  ],
  "scripts": {
    "build": "npm run cleanup && vite build --mode production",
    "cleanup": "rimraf build/www",
    "e2e": "playwright test --config playwright.config.mts",
    "e2e:headed": "playwright test --config playwright.config.mts --headed",
    "e2e:prepare": "tsx ./scripts/prepare-playwright-report.mts",
    "e2e:typecheck": "tsc --project tsconfig.e2e.json",
    "e2e:ui": "playwright test --config playwright.config.mts --ui",
    "format": "oxfmt --write 'src/main/javascript/**/*.{mts,css,scss}'",
    "format:check": "oxfmt --check 'src/main/javascript/**/*.{mts,css,scss}'",
    "lint:deadcode": "node ./scripts/check-dead-code.mjs",
    "lint:i18n": "node ./scripts/check-translations.mjs",
    "lint:spacing": "node ./scripts/check-spacing-grid.mjs",
    "lint": "oxlint --config .oxlintrc.json ./src/main/javascript",
    "lint:fix": "oxlint --config .oxlintrc.json --fix ./src/main/javascript",
    "test": "npm run format:check && npm run lint && npm run lint:spacing && npm run lint:deadcode && npm run lint:i18n && npm run typecheck:web",
    "typecheck:web": "tsc --project tsconfig.json",
    "start": "vite --host=0.0.0.0 --port=3000"
  }
}
