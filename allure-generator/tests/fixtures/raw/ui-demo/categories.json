[
  {
    "name": "Ignored tests",
    "messageRegex": ".*ignored.*",
    "matchedStatuses": [
      "skipped"
    ]
  },
  {
    "name": "Infrastructure problems",
    "messageRegex": ".*RuntimeException.*",
    "matchedStatuses": [
      "broken"
    ]
  },
  {
    "name": "Product defects",
    "messageRegex": ".*Element not found.*",
    "matchedStatuses": [
      "failed"
    ]
  },
  {
    "name": "Test defects",
    "traceRegex": ".*AssertionFailedError.*",
    "matchedStatuses": [
      "failed",
      "broken"
    ]
  }
]
